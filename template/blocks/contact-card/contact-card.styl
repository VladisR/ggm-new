.contact-card
    padding lf(12px, 20px) lf(12px, 20px) lf(14px, 22px)
    background var(--surface3)
    display: grid
    grid-template-columns: auto auto 1fr;
    align-items: start
    &__name,
    &__meta-role,
    &__meta-company,
    &__socials
        // grid-column: 2;
        justify-self: start

    &__col
        display: contents;

    &__avatar
        flex none
        margin-right lf(16px, 16.01px)
        color var(--white)
        grid-column: 1;
        grid-row: span 3;
        &-img
            border-radius 100%
            overflow hidden
            width lf(40px, 60px)
            height lf(40px, 60px)
            position relative
            font-size lf(18, 24)
            text-align center
            font-weight 500
            line-height lf(40px, 60px)
            text-transform uppercase
            &:before
                content ''
                position absolute
                left 0
                top 0
                width 100%
                height 100%
                box-shadow inset 0 0 0 1px var(--neutral-500)
                border-radius 100%
                opacity 0.2
        span
            width 100%
            height 100%
            display block
        img
            display block

    &__name
        font-weight 500
        font-size lf(16, 18)
        line-height lf(20px, 28px)
        margin-bottom lf(2px, 4px)
        color var(--neutral-900)
        grid-column: 2 / span 2;
        grid-row: 1;


    &__role,
    &__company
        font-size lf(14, 14.01)
        line-height lf(20px, 20.01px)

    &__role
        grid-column: 2;
        grid-row: 2;
        +
            & ^[0]
                &__company
                    padding-left lf(12px, 12.01px)
                    margin-left lf(8px, 8.01px)
                    &:before
                        content ''
                        width lf(4px, 4.01px)
                        height lf(4px, 4.01px)
                        border-radius 100%
                        position absolute
                        left 0
                        top 50%
                        transform translateY(-50%)
                        background var(--neutral-400)

    &__company
        position relative
        // display inline
        // grid-row: 2;
        grid-column: 3;
        grid-row: 2;

    &__socials
        grid-column: 2 / span 2;
        grid-row: 3;
        margin-top lf(10px, 10.01px)
        &-items
            display flex
            gap 0 lf(16px, 10.01px)
        &-link
            text-decoration none
            width lf(20px, 20.01px)
            height lf(20px, 20.01px)
            display flex
            img, svg
                margin auto
                width 76%
            svg
                transition 0.25s fill, 0.25s transform

        &-link
            &:hover
                svg
                    transform translateY(-2px)
                    path
                        fill var(--teal-300)

    @media (min-width: $mq.lg)
        align-items center



.contacts-list
    @media (min-width: $mq.md)
        &--horisontal

            .contact-card
                display: table-row
                background none
                border-bottom 1px solid var(--light-grey)

                > *
                    padding lf(8px, 8.01px) lf(20px, 20.01px)
                &__col
                    display: table-cell !important
                    vertical-align: middle
                    padding: lf(8px, 8.01px) 0 lf(8px, 8.01px) lf(20px, 20.01px)
                    font-size 0
                    width 100%
                    max-width 35.7%
                    white-space: nowrap

                    .contact-card__avatar
                        display: inline-block !important
                        vertical-align: middle
                        &-img
                            width lf(40px, 40.1px)
                            height lf(40px, 40.1px)
                        span
                            font-size lf(18, 18.01)
                            line-height lf(39px, 39.01px)

                    .contact-card__name
                        display: inline-block !important
                        vertical-align: middle
                        padding-left: 0
                        width: calc(100% - lf(56px, 56.1px))
                        white-space normal
                        font-size lf(16, 16.01)

                &__role
                    display: table-cell !important
                    vertical-align: middle

                &__company
                    display: table-cell !important
                    vertical-align: middle

                    &:before
                        display none

                &__socials
                    display: table-cell !important
                    vertical-align: middle
                    white-space: nowrap
                    &-items
                        justify-content space-between

                    > a
                        display: inline-flex
