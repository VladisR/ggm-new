.catalog
    padding lf(52px, 120px) 0

    &__items
        display flex
        flex-direction column
        row-gap lf(16px, 20px)

        padding-left lf(16px, 72px)
        padding-right lf(16px, 72px)

        margin-left lf(-16px, -72px)
        margin-right lf(-16px, -72px)

        @media (min-width: $mq.md)
            display grid
            grid-template-columns: repeat(2, 1fr);
            gap lf(20px, all)

        @media (min-width: $mq.lg)
            grid-template-columns: repeat(2, 1fr);

        @media (min-width: $mq.xl)
            grid-template-columns: repeat(3, 1fr);

    .header-block
        max-width lf(636px, all)
        @media (min-width: $mq.lg)
            max-width lf(636px, all)
            margin-left auto
            margin-right auto
            text-align center

    &__button
        text-align center
        margin-top lf(40px, 48px)
        .site-button
            width 100%
            @media (min-width: $mq.md)
                width auto

    &__body
        display none
        &.is-visible
            display block

    .tabs-titles
        margin-bottom lf(32px, all)
        @media (min-width: $mq.lg)
            &__items
                justify-content center


.catalog[data-mobile-column="true"]
    .catalog__items
        display: grid !important;
        grid-template-rows: repeat(2, 1fr);
        grid-auto-flow: column;
        grid-auto-columns: max-content;
        overflow-x: auto;
        gap: lf(16px, 24px);
        scrollbar-width: none;

        &::-webkit-scrollbar
            display: none;

        @media (min-width: $mq.lg)
            overflow-x: visible;
            grid-auto-flow: row;
            grid-template-rows: auto;
            grid-auto-columns: auto;
            display grid
            grid-template-columns: repeat(2, 1fr);

        @media (min-width: $mq.xl)
            grid-template-columns: repeat(3, 1fr);
