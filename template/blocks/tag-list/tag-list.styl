.tag-list
    margin-top lf(36px, 60px)
    margin-bottom lf(28px, 31px)
    display flex
    &__label
        display none
        @media (min-width: $mq.md)
            flex none
            font-weight 500
            display block
            font-size lf(14, 14.01px)
            margin-right lf(16px, 16.01px)
            margin-top lf(4px, 4.01px)
    &__items
        margin-bottom lf(-8px, -9px)

        margin-left lf(-16px, -72px)
        margin-right lf(-16px, -72px)

        padding-left lf(16px, 72px)
        padding-right lf(16px, 72px)

        display flex
        flex-flow row
        overflow hidden
        overflow-x auto

        scrollbar-height none
        scrollbar-width: none;
        -ms-overflow-style: none;
        &::-webkit-scrollbar
            display none

    &__item
        flex none
        margin-right lf(8px, 9px)
        margin-bottom lf(8px, 9px)
        border 1px solid var(--blue)
        text-decoration none
        padding lf(7px, 7.01px) lf(15px, 15.01px)
        text-transform uppercase
        font-size lf(12, 12.01)
        line-height lf(16px, 16.01px)
        border-radius 1px
        letter-spacing lf(0.11px, 0.12px)
        font-weight 500
        text-align center
        background none
        cursor pointer

        &:hover,
        &.is-active
            background var(--teal-400)
            color var(--white)
            border-color var(--teal-400)

        &:last-child
            margin-right 0

    @media (min-width: $mq.lg)
        &__items
            flex-wrap wrap
            margin 0 0 0 lf(-8px, -9px)
            padding 0

        &__item
            margin-left lf(8px, 9px)
            margin-right 0

    @media (min-width: $mq.hd)
        &__item
            letter-spacing lf(0.09px, 0.10px)
