.hero
    &__in
        &.swiper
            margin-left 0
            margin-right 0

    &__navigation
        display none

    &__item
        position relative
        &.swiper-slide
            display flex
            flex-direction column
            height auto

        &-image
            left 0
            margin-top lf(100px, all)
            width 100%
            img
                width 100%
                display block

        &-in
            width 100%
            position relative
            margin-top -110px
            padding 50px lf(16px, 108px) 32px
            display flex
            flex-direction column
            position relative
            flex 1
            &:before,
            &:after
                content ''
                position absolute
                left -5px
                right -5px
            &:before
                top 0
                // height 80%
                height 242px
                background linear-gradient(180deg, rgba(16,16,19,0) 0%, rgba(16,16,19,0.9) 25%, #101013 38%)

            &:after
                background #101013
                bottom 0
                height 40%

        &-title,
        &-text,
        &-button
            position relative
            z-index 1

        &-title
            color var(--white)
            font-size lf(20, 36)
            line-height lf(32px, 48px)
            margin-bottom lf(12px, 16px)
            font-weight bold

        &-text
            font-size lf(16, 18)
            color var(--neutral-400)
            margin-bottom lf(16px, 44px)

        &-button
            .site-button
                padding 0
                color var(--teal-300)
                background none
                &:hover
                    background none
                    color var(--teal-200)
                .svg-icon
                    fill var(--teal-300)

    @media (min-width: $mq.lg)
        &__item
            &:before
                content ''
                position absolute
                left 0
                top 0
                right 0
                height lf(200px, 336px, (992 1440))
                z-index 1
                background: linear-gradient(1.29deg, rgba(16, 16, 19, 0) 8%, rgba(16, 16, 19, 0.713942) 67.81%, rgba(16, 16, 19, 0.9) 98.9%);

            &:after
                content ''
                position absolute
                left 0
                right 0
                bottom 0
                height lf(200px, 337px)
                background: linear-gradient(359.53deg, rgba(16, 16, 19, 0.9) 0.4%, rgba(16, 16, 19, 0) 99.6%);


            &-image
                margin-top 0
                position absolute
                left 0
                top 0
                width 100%
                height 100%
                img
                    height 100%
                    object-fit cover
            &-in
                min-height 100svh
                margin-top 0
                justify-content center
                padding-top lf(109px, 128px)
                &:after,
                &:before
                    opacity 0
            &-container
                max-width lf(624px, 625px)
            &-title
                text-transform uppercase

            &-button
                .site-button
                    border 1px solid var(--white)
                    color var(--white)
                    padding lf(13px, all) lf(27px, all)
                    .svg-icon
                        fill var(--white)
                    &:hover
                        color var(--white)
                        background: rgba(0, 67, 70, 0.4);
                        border: 1px solid var(--teal-400);



        div.swiper-pagination
            position absolute
            left 0
            top auto
            right 0
            bottom lf(30px, 67px)
            margin-top 0

        .swiper-pagination-bullet
            background rgba(#fff, 0.3)
            opacity 1
            &.swiper-pagination-bullet-active
                background var(--white)
                opacity 1

        &__shadow

            position: absolute;
            left: -16.74%;
            right: 51.47%;
            top: -10.3%;
            bottom: -8.52%;

            background: #000000;
            filter: blur(326.521px);
            transform: matrix(1, 0, 0, 1, 0, 0);
            z-index 1


        &__navigation
            display block
            z-index 1

            .swiper-button.swiper-button-prev
                left lf(14px, 32px)
                transform translate(-200%, -50%) scale(0.5)
                transition 0.5s all

            .swiper-button.swiper-button-next
                right lf(14px, 32px)
                transform translate(200%, -50%) scale(0.5)
                transition 0.5s all

        &:hover
            & ^[0]
                &__navigation
                    .swiper-button.swiper-button-prev
                        transform translate(0, -50%) scale(1)

                    .swiper-button.swiper-button-next
                        transform translate(0, -50%) scale(1)
