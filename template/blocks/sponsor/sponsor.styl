.sponsor
    padding lf(20px, 29px) 0
    margin lf(36px, 48px) 0
    border-top 1px solid var(--light-grey)
    border-bottom 1px solid var(--light-grey)
    &__title
        font-size lf(12, 14)
        letter-spacing 0.01em
        font-weight 500
        text-transform uppercase
        color var(--teal-300)
        line-height lf(16px, 20px)
        margin-bottom lf(12px, 12.01px)
    &__text
        margin-bottom lf(16px, 16.01px)

    &__image
        display block
        overflow hidden
        img
            display block
            width 100%
            transition 0.25s transform
        &:hover
            img
                transform scale(1.02)
