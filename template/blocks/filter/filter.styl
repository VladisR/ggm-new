.filter
    position fixed
    left 0
    top 0
    width 100%
    height 100%
    z-index 50
    pointer-events none
    &.is-opened
        pointer-events auto
        &:before
            opacity 1
        & ^[0]
            &__in
                transform translateX(0)


    &.is-mobile-filter
        & ^[0]
            &__in
                transition 0.5s transform

    &:before 
        content ''
        position absolute
        left 0
        top 0
        width 100%
        height 100%
        background unquote("rgba(var(--black), 0.7)")
        opacity 0
        transition 0.5s opacity
        pointer-events none


    &__in
        position absolute
        right 0
        top 0
        height 100%
        width 100%
        max-width 460px
        background var(--white)
        font-weight 500
        display flex
        flex-direction column
        transform translateX(100%)

    &__header
        display flex
        align-items center
        flex none
        padding-top lf(22px, 22.01px)
        padding-bottom lf(22px, 22.01px)

    &__close
        width lf(24px, 24.01px)
        height lf(24px, 24.01px)
        display flex
        border 0
        background none
        padding 0
        margin-right lf(12px, 12.01px)
        &:active
            background var(--teal-400)
            .svg-icon
                fill var(--white)

        .svg-icon
            width 58.4%
            height 58.4%
            margin auto
            fill var(--surface2)


    &__header,
    &__group-name,
    &__group-body,
    &__footer
        padding-left lf(24px, 24.01px)
        padding-right lf(24px, 24.01px)

    &__header,
    &__group
        border-bottom 1px solid var(--light-grey)

    &__container
        flex 1
        overflow-y auto

    &__title
        font-size lf(18, 18.01)
        line-height lf(28px, 28.01px)
        color var(--neutral-900)
        margin-right auto

    &__reset
        font-size lf(14, 14.01)
        line-height lf(20px, 20.01px)
        padding 0
        border 0
        font-weight 500
        background none
        cursor pointer
        color var(--neutral-600)
        &:hover
            color var(--teal-300)

    div&__group
        // &:last-child
        //     border 0

        &-body
            &-in
                padding-bottom lf(24px, 24.01px)

        .search-form
            margin 0 0 lf(22px, 22.01px)
            input
                padding-top lf(2px, 2.01px)
                font-size lf(14, 14.01)

        &.is-closed
            .svg-icon
                &--arr-d
                    transform rotateX(0)

        &:nth-child(2)
            ~
                & ^[0]
                    &__group
                        & ^[0]
                            &__group-name
                                .svg-icon
                                    transform rotateX(0)
                                &.is-active
                                    .svg-icon
                                        transform rotateX(180deg)
                            &__group-body
                                display none

    &__group-name
        padding-top lf(24px, 24.01px)
        padding-bottom lf(24px, 24.01px)
        font-size lf(18, 18.01)
        line-height lf(28px, 28.01px)
        display flex
        align-items center
        text-align left
        color var(--neutral-900)
        width 100%
        border 0
        background none
        font-weight 500
        cursor pointer
        &:hover
            color var(--teal-400)

        .svg-icon
            margin-left auto
            flex none
            width lf(10px, 10.01px)
            height lf(6px, 6.01px)
            fill var(--surface2)
            transition 0.25s transform
            transform rotateX(180deg)

    &__option
        margin-bottom lf(14px, 14.01px)
        &:last-child
            margin-bottom 0

        &:nth-child(10 of .filter__option)
            ~ .filter__option
                display none

        &-label
            display inline-flex
            font-weight 400
            vertical-align bottom
            cursor pointer

    &__footer
        padding-top lf(20px, 24.01px)
        padding-bottom lf(20px, 24.01px)
        box-shadow 0 -1px 5px rgba(#08171F, 0.08)
        .site-button
            width 100%
            padding-top lf(10px, 10.01px)
            padding-bottom lf(10px, 10.01px)
            span
                margin 0 5px

    .checkbox
        margin-top lf(1px, 1.01px)

    &__more
        padding 0
        border 0
        background none
        cursor pointer
        margin-top lf(6px, 6.01px)
        font-size lf(14, 14.01)
        line-height lf(20px, 20.01px)
        color var(--teal-400)
        font-weight 500
        &:hover
            color var(--teal-300)

    .has-visible-children
        & ^[0]
            &__option
                &:nth-child(10)
                    ~ .filter__option
                        display block

    .toggle-switch
        display flex
        align-items center
        justify-content space-between
        &__name
            font-size lf(18, all)
            line-height lf(28px, all)
            margin-right lf(3px, all)

        .checkbox
            margin-right 0

    @media (min-width: $mq.xl)
        position static
        height auto
        border 1px solid var(--light-grey)
        pointer-events auto
        &__close,
        &:before,
        &__footer
            display none
        &__in
            position static
            transform none
            background none

        &.is-mobile-filter
            & ^[0]
                &__in
                    transition none

        div&__group
            &:last-child
                border 0

.filter
    &--catalog
        & ^[0]
            &__footer
                display block
                box-shadow none
                border-top 1px solid var(--light-grey)
                color var(--neutral-900)
