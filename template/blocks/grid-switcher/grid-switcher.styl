.grid-switcher
    display none
    @media (min-width: $mq.md)
        display flex
        margin-left auto


        &__item
            width lf(32px, all)
            height lf(32px, all)
            display flex
            margin-left lf(8px, all)
            border 0
            background none
            cursor pointer
            .svg-icon
                margin auto
                fill var(--blue)
                width 95%
                height 95%
                transition 0.25s fill
                svg
                    width 100%
                    height 100%

        &__item
            &:hover
                .svg-icon
                    fill var(--teal-500)

        &__item
            &.is-active
                background-color var(--surface3)
                cursor auto
                .svg-icon
                    fill var(--teal-500)
