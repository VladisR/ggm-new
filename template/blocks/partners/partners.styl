.partners
    position relative
    &__bg
        position absolute
        left 0
        top 0
        width 100%
        height 100%
        img
            width 100%
            height 100%
            object-fit cover

    &__in
        position relative
        color var(--white)
        padding-top lf(52px, 100px)
        padding-bottom lf(52px, 92px)

    &__title
        color var(--white)
        text-align center
        margin-bottom lf(16px, 48px)

    &__items
        display grid
        grid-template-columns repeat(2, 1fr)
        padding 0 lf(17.5px, 0px)
        gap 0 lf(24px, all)

    &__item
        height lf(117px, 152px)
        display flex
        align-items center
        justify-content center
        padding lf(3.85px, all)
        img
            background none
            max-width 100%

    @media (min-width: $mq.sm)
        &__items
            grid-template-columns repeat(3, 1fr)

    @media (min-width: $mq.md)
        &__items
            grid-template-columns repeat(4, 1fr)

    @media (min-width: $mq.lg)
        &__items
            grid-template-columns repeat(6, 1fr)
