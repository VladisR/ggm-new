.masonry-grid
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    align-items: start;
    gap: lf(32px, 48px) lf(16px, 24px);
    margin-bottom lf(45px, 48px)

    @media (min-width: $mq.md)
        grid-template-columns: repeat(3, 1fr);

    @media (min-width: $mq.xl)
        grid-template-columns: repeat(4, 1fr);

    &__item
        text-decoration none
        &:hover
            & ^[0]
                &__item
                    &-image
                        img
                            transform scale(1.02)
                    &-title
                        color var(--teal-400)
            .play-icon
                background var(--teal-400)

        &-content
            display block
            position relative

        &-image
            display block
            margin-bottom lf(12px, 20px)
            overflow hidden
            border-radius: lf(4px, 4.01px);
            img
                width 100%
                height 100%
                object-fit cover
                display block
                margin-bottom -1px
                transition 0.25s transform
                will-change transform

        .post-meta
            margin-bottom lf(8px, 12px)

        &-title
            font-size lf(16, 16.01)
            font-weight 500
            color var(--neutral-900)
            transition 0.25s color
            text-decoration none
            display inline-block

        .play-icon
            width lf(40px, 64px)
            height lf(40px, 64px)
            z-index 1
