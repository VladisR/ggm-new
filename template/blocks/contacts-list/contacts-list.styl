.contacts-list
    margin-bottom lf(36px, all)

    &__header
        display none

    &__items
        display flex
        flex-direction column
        row-gap lf(16px, 20px)

        @media (min-width: $mq.md)
            display grid
            grid-template-columns: repeat(2, 1fr);
            gap lf(20px, all)

        @media (min-width: $mq.lg)
            grid-template-columns: repeat(2, 1fr);


.contacts-list
    &.table-view
        & ^[0]
            &__header
                display none
        @media (min-width: $mq.xl)
            display block
            & ^[0]
                &__header
                    background var(--surface3)
                    display: table-row
                    &-th
                        padding lf(16px, 16.01px) lf(20px, 20.01px)
                        font-weight 500

                        display: table-cell
                        vertical-align: middle
                        white-space: nowrap
                        &:nth-child(2)
                            width 200px
                        &:nth-child(3)
                            width 224px
                        &:nth-child(4)
                            width 196px
                &__items
                    display: table
                    width: 100%
                    border-collapse: collapse
