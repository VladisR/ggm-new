.events-calendar
    position relative
    overflow hidden

    &__bg
        position absolute
        left 0
        top 0
        width 100%
        height 100%
        img
            width 100%
            height 100%
            object-fit cover

    &__in
        padding-top lf(158px, 216px)
        padding-bottom lf(103px, 119px)
        position relative

    &__overtitle
        text-align center
        color var(--white)
        font-weight bold
        font-size vw(90, 393)
        display flex
        justify-content center
        line-height 100%
        text-transform: uppercase;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.25) 7.22%, rgba(255, 255, 255, 0.05) 83.06%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-fill-color: transparent;

        margin-left lf(-16px, -72px)
        margin-right lf(-16px, -72px)
        margin-bottom -6.3%

        @media (min-width: $mq.lg)
            margin-left 0
            margin-right 0
            font-size lf(180px, all)
            margin-bottom lf(-52px, all)


    &__title
        margin-top 0
        margin-bottom lf(21px, 11.67px)
        color var(--teal-500)
        font-size lf(18, 20)
        line-height lf(28px, 32px)
        @media (min-width: $mq.lg)
            text-transform uppercase

    &__container
        padding-top lf(16px, 32px)
        padding-bottom lf(16px, 32px)

        padding-left lf(16px, 72px)
        padding-right lf(16px, 72px)

        margin-left lf(-16px, -72px)
        margin-right lf(-16px, -72px)

        background: var(--white);
        // backdrop-filter: blur(7.5px);
        border-top 1px solid rgba(#E7F9FA, 0.15)
        border-bottom 1px solid rgba(#E7F9FA, 0.15)
        overflow hidden

    &__items
        margin-top lf(28px, all)
        &.swiper
            width auto
            overflow visible
            padding-left lf(16px, 72px)
            padding-right lf(16px, 72px)
            margin-left lf(-16px, -72px)
            margin-right lf(-16px, -72px)

    &__row
        margin-top lf(28px, all)
        display flex
        align-items center

    &__reset
        display none
        @media (min-width: $mq.sm)
            cursor pointer
            display inline-flex
            align-items center
            color var(--teal-500)
            padding 0
            margin-left lf(28px, all)
            font-weight 500
            font-size lf(14, all)
            border 0
            background none
            &:hover
                color var(--teal-400)
                .svg-icon
                    svg
                        transform rotate(90deg)
            .svg-icon
                width lf(9.33px, all)
                height lf(9.33px, all)
                margin-left lf(9.34px, all)
                margin-top lf(3px, all)
                svg
                    transition 0.25s transform

    &__controls
        display none
        @media (min-width: $mq.md)
            display flex
            align-items center
            margin-left auto
            .swiper-button
                margin-left lf(32px, all)
                position static
                background none
                border 0
                backdrop-filter none
                margin-top 0
                transform none
                width lf(32px, all)
                height lf(32px, all)
                &:hover
                    background none
                    .svg-icon
                        fill var(--teal-500)

                &.swiper-button-disabled
                    opacity 0.5
                    .svg-icon
                        fill var(--neutral-500) !important

                .svg-icon
                    width 62.5%
                    fill var(--neutral-500)

    @media (min-width: $mq.lg)
        &__container
            padding 0
            margin 0
            background var(--white)
            padding lf(32px, all)


        &__items
            &.swiper
                margin-left 0
                margin-right 0
                padding-left 0
                padding-right 0
                overflow hidden
