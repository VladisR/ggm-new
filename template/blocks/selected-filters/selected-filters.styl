.selected-filters
    display flex
    flex-wrap wrap
    align-items center
    margin-top lf(-16px, -16.01px)
    margin-left lf(-16px, -16.01px)
    margin-bottom lf(12px, 12.01px)
    font-size lf(14, 14.01px)
    line-height lf(20px, 20.01px)
    &__item
        display flex
        align-items center
        margin 0 0 lf(16px, 16.01px) lf(16px, 16.01px)
        &-remove
            width lf(16px, 16.01px)
            height lf(16px, 16.01px)
            margin-left lf(2px, 2.01px)
            display flex
            padding-top lf(2px, 2.01px)
            cursor pointer
            &:hover
                .svg-icon
                    fill var(--teal-300)
                    transform rotate(90deg)
            .svg-icon
                margin auto
                width lf(9.33px, 9.34px)
                height lf(9.33px, 9.34px)
                transition 0.25s fill, 0.25s transform
                svg
                    width 100%
                    height 100%


    &__reset
        background none
        border 0
        padding 0
        cursor pointer
        margin 0 0 lf(17.4px, 17.5px) lf(16px, 16.01px)
        font-weight 500
        color var(--teal-400)
        &:hover
            color var(--teal-300)
