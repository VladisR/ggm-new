.mobile-menu
    position fixed
    left 0
    top 0
    width 100%
    height 100%
    z-index 50
    pointer-events none
    &.is-opened
        pointer-events auto
        &:before
            opacity 1
        & ^[0]
            &__in
                transform translateX(0)


    &.is-mobile-filter
        & ^[0]
            &__in
                transition 0.5s transform
    &:before
        content ''
        position absolute
        left 0
        top 0
        width 100%
        height 100%
        background unquote("rgba(var(--black), 0.7)")
        opacity 0
        transition 0.5s opacity
        pointer-events none

    &__in
        position absolute
        left 0
        top 0
        height 100%
        width 100%
        max-width 460px
        background var(--white)
        font-weight 500
        display flex
        flex-direction column
        transform translateX(-100%)
        transition 0.5s transform

    &__header,
    &__footer-link
        padding-left lf(16px, all)
        padding-right lf(16px, all)

    &__header
        display flex
        align-items center
        padding-top lf(10.76px, all)
        padding-bottom lf(10.76px, all)
        flex none
        .site-logo
            margin-right auto
            width lf(63px, 97px, (300 393))
            svg
                width 100%
                height 100%
            @media (min-width: 393px)
                width lf(97px)

    &__close
        cursor pointer
        width lf(24px, all)
        height lf(24px, all)
        display flex
        padding 0
        border 0
        background none
        .svg-icon
            margin auto
            width lf(14px, all)
            height lf(14px, all)
            fill var(--surface2)
            transition 0.25s transform, 0.25s fill
        &:active
            .svg-icon
                transform rotate(90deg)
                fill var(--teal-300)

    &__content
        flex 1
        overflow-y auto
        padding lf(24px, all) 0 0

    &__menu

        ul
            padding 0
            margin 0
            list-style none

            li
                padding 0
                margin-bottom 0
                border-bottom 1px solid var(--light-grey)
                &:before
                    display none
                > a:hover
                    color var(--teal-400)
                a
                    padding lf(16px, all) lf(14px, all)
                    text-decoration none
                    display block
                    position relative
                    color var(--neutral-900)
                    border-left lf(4px, all) solid transparent

                    .svg-icon
                        position absolute
                        right lf(19px, all)
                        top 50%
                        transform translateY(-50%)
                        width lf(12px, all)
                        height lf(6.75px, all)
                        fill var(--neutral-600)
                        svg
                            transition 0.25s transform

                ul
                    display none
                    padding-left lf(32px, all)
                    li
                        border 0
                        &:last-child
                            margin-bottom lf(10px, all)
                        a
                            display inline-block
                            padding lf(10px, all) 0
                            color var(--neutral-800)
                            border 0
                            font-size lf(14, all)
                            line-height lf(20px, all)
                            &:hover
                                color var(--teal-400)

                        &.current-menu-item
                            > a
                                background none
                                &:before
                                    content ''
                                    background var(--teal-400)
                                    width lf(8px, all)
                                    height lf(2px, all)
                                    position absolute
                                    left lf(-16px, all)
                                    top lf(19px, all)


                &.current-menu-item
                    > a
                        color var(--teal-400)
                        background var(--surface3)
                        border-left-color var(--teal-400)
                        .svg-icon
                            svg
                                transform rotateX(180deg)
                    > ul
                        display block
        .is-opened
            > a
                color var(--teal-400)
                .svg-icon
                    svg
                        transform rotateX(180deg)

    &__footer
        flex none
        box-shadow 0 -1px 5px rgba(#08171F, 0.08)
        &-link
            padding-top lf(16px, all)
            padding-bottom lf(16px, all)
            display block
            text-decoration none
            background var(--white)
            font-size lf(14px, all)
            line-height lf(20px, all)

    @media (min-width: $mq.lg)
        display none
