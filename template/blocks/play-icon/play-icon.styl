.play-icon
    position absolute
    left 50%
    top 50%
    transform translate(-50%, -50%)
    width lf(40px, 84px)
    height lf(40px, 84px)
    border 2px solid rgba(#E7F9FA, 0.5)
    border-radius 100%
    display flex
    padding-left 3px
    background unquote('rgba(var(--white-rgb), 0.3)')
    transition 0.25s background
    cursor pointer
    &:hover
        background var(--teal-400)
    .svg-icon
        margin auto
        width 55%
        height 55%
        fill var(--white)
        svg
            width 100%
            height 100%
